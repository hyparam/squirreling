  },
  "dependencies": {
    "hyparquet": "1.25.1",
    "hyparquet-compressors": "1.1.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "9.39.2",
    "eslint-plugin-jsdoc": "62.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
