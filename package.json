{
  "name": "squirreling",
  "version": "0.11.2",
  "description": "Squirreling Async SQL Engine",
  "author": "Hyperparam",
  "homepage": "https://hyperparam.app",
  "keywords": [
    "sql",
    "data",
    "dataset",
    "hyperparam",
    "hyparquet",
    "parquet",
    "query",
    "relational"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyparam/squirreling.git"
  },
  "type": "module",
